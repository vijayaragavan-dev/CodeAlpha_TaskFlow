# =============================================================================
# TaskFlow Environment Configuration
# =============================================================================
# Copy this file to .env and replace placeholders with actual values.
# NEVER commit .env to version control.
# =============================================================================

# Flask Configuration
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# Environment: development / production / testing
FLASK_ENV=development

# Server Port (default 5000)
PORT=5000

# MySQL Database Connection
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DB=taskflow

# Connection Pooling (optional, defaults shown)
# DB_POOL_NAME=taskflow_pool
# DB_POOL_SIZE=5
# DB_POOL_RECYCLE=3600

# Security
# Set to "true" when using HTTPS (Render, Railway, production)
# SESSION_COOKIE_SECURE=false

# CORS allowed origins (comma-separated, or * for development)
# ALLOWED_ORIGINS=*

# MySQL SSL (optional -- set only if cloud DB requires SSL)
# MYSQL_SSL_CA=/path/to/ca.pem
# MYSQL_SSL_VERIFY=true

# Rate Limiting (optional, defaults shown)
# RATELIMIT_ENABLED=True
# RATELIMIT_GLOBAL=200 per hour
# RATELIMIT_LOGIN=10 per minute
# RATELIMIT_REGISTER=5 per minute
